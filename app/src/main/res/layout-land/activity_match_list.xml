<?xml version="1.0" encoding="utf-8"?>

<!-- Match List screen in landscape orientation -->

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/matchList"
    android:padding="16dp"
    tools:context=".MatchListActivity">

    <!-- Back button -->
    <ImageButton
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:id="@+id/buttonBack"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back"
        android:src="@drawable/backarrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Title of the page -->
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/textViewHistory"
        android:layout_margin="12dp"
        android:text="@string/played_matches"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/dynamicListGames"
        app:layout_constraintTop_toBottomOf="@id/buttonBack"/>

    <!-- RecyclerView to host the list of games played, order from most recent to least recent -->
    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:id="@+id/dynamicListGames"
        android:layout_margin="24dp"
        app:layout_constraintStart_toEndOf="@id/textViewHistory"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_game"/>
</androidx.constraintlayout.widget.ConstraintLayout>