<?xml version="1.0" encoding="utf-8"?>

<!-- Home Screen in LandScape orientation -->

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeScreen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- On right side place 3x2 matrix of colors -->
    <GridLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:id="@+id/buttonsGrid"
        android:layout_margin="12dp"
        android:columnCount="2"
        android:rowCount="3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/rightSide"
        app:layout_constraintHorizontal_weight="1">

        <!-- All the buttons, same order as in the portrait orientation -->
        <TextView
            android:id="@+id/buttonRed"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="#e85a41"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="R"
            android:textColor="#fcf3eb"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/buttonGreen"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="#47d93f"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="G"
            android:textColor="#fcf3eb"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/buttonBlue"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="#3b5fd4"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="B"
            android:textColor="#fcf3eb"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/buttonMagenta"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="#d43bd4"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="M"
            android:textColor="#fcf3eb"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/buttonYellow"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="#f2d933"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Y"
            android:textColor="#fcf3eb"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/buttonCyan"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="#3ec1ed"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="C"
            android:textColor="#fcf3eb"
            android:textStyle="bold" />
    </GridLayout>

    <!-- On right side I wrap the sequence TextView and Cancel and EndOfGame buttons in a LinearLayout with vertical orientation -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:id="@+id/rightSide"
        android:layout_margin="12dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/buttonsGrid"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="1">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/textViewSequence"
            android:layout_marginBottom="24dp"
            android:background="#e6e8e8"
            android:minHeight="80dp"
            android:padding="12dp"
            android:text="@string/sequence_label"
            android:textSize="16sp" />

        <!-- LinearLayout wrapping the Cancel and EndOfGame buttons with horizontal orientation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/bottomButtons"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonStartGame"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/start_game" />

            <Button
                android:id="@+id/buttonEndOfGame"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/end_of_game" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>