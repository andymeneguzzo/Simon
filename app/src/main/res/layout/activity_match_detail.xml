<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/matchDetail"
    android:padding="16dp"
    tools:context=".MatchDetailActivity">

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/textViewDetailTitle"
        android:text="@string/match_detail"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/detailContainer"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#e6e8e8"
        app:layout_constraintTop_toBottomOf="@id/textViewDetailTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:id="@+id/textViewPressCount"
            android:gravity="center"
            android:text="6"
            android:textSize="22dp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/textViewSequence"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:textSize="18sp"
            android:text="R, G, B, M, Y, C" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>