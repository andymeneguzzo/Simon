<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/matchList"
    tools:context=".MatchListActivity"
    android:padding="16dp">

    <!-- Could use back gesture, but for better navigation UX I'll add a Back button -->
    <ImageButton
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:id="@+id/buttonBack"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Indietro"
        android:src="@drawable/backarrow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Title of the page -->
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/textViewHistory"
        android:layout_margin="12dp"
        android:text="Partite giocate"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/buttonBack"
        app:layout_constraintStart_toEndOf="@id/buttonBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/buttonBack"/>

    <!-- RecyclerView to host the list of games played, order from most recent to least recent -->
    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:id="@+id/dynamicListGames"
        android:layout_margin="12dp"
        app:layout_constraintTop_toBottomOf="@id/buttonBack"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_game"/>
</androidx.constraintlayout.widget.ConstraintLayout>